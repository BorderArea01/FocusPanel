<UserControl x:Class="FocusPanel.Views.FileOrganizerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:FocusPanel.ViewModels"
             xmlns:converters="clr-namespace:FocusPanel.Converters"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:FileOrganizerViewModel}"
             d:DesignHeight="700" d:DesignWidth="450">
    <UserControl.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- File Item Style (Cleaner, Windows 11-like) -->
        <Style x:Key="FileItemContainerStyle" TargetType="Border">
            <EventSetter Event="MouseMove" Handler="FileCard_MouseMove"/>
            <Setter Property="Width" Value="{Binding DataContext.CardWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Setter Property="Height" Value="{Binding DataContext.CardHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource MaterialDesignDivider}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
                </Trigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryHueLightBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Partition Entrance Animation -->
        <Style x:Key="PartitionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource MaterialDesignPaper}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
            <Setter Property="Padding" Value="0"/>
            <!-- Removed Fixed Width -->
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignDivider}"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="10"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.3"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.3">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.Resources>
            <converters:BindingProxy x:Key="VmProxy" Data="{Binding}" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header / Toolbar (Responsive) -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,16" Orientation="Horizontal">
            <TextBlock Text="Desktop" Style="{StaticResource MaterialDesignHeadline6TextBlock}" VerticalAlignment="Center" Margin="0,0,16,8" FontWeight="Bold" Foreground="{DynamicResource MaterialDesignBody}"/>
            
            <!-- View Mode Switcher -->
            <Border CornerRadius="20" Background="{DynamicResource MaterialDesignDivider}" Padding="4" Margin="0,0,16,8" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}"
                                 IsChecked="{Binding IsPersonalizedView}"
                                 Command="{Binding ToggleViewCommand}"
                                 Content="Custom"
                                 ToolTip="Custom Partitions"
                                 Margin="0,0,4,0"/>
                    <RadioButton Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}"
                                 IsChecked="{Binding IsPersonalizedView, Converter={StaticResource InverseBoolConverter}}"
                                 Command="{Binding ToggleViewCommand}"
                                 Content="Timeline"
                                 ToolTip="Group by Date"/>
                </StackPanel>
            </Border>

            <!-- Partition Creation (Visible in Personalized Mode) -->
            <StackPanel Orientation="Horizontal" Visibility="{Binding IsPersonalizedView, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,16,8" VerticalAlignment="Center">
                    <TextBox Text="{Binding NewPartitionName, UpdateSourceTrigger=PropertyChanged}" 
                            materialDesign:HintAssist.Hint="New Partition"
                            Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                            Width="100" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <Button Command="{Binding CreatePartitionCommand}" 
                        Style="{StaticResource MaterialDesignFloatingActionMiniButton}" 
                        ToolTip="Create Partition"
                        Width="32" Height="32"
                        Background="{DynamicResource PrimaryHueMidBrush}"
                        BorderBrush="{DynamicResource PrimaryHueMidBrush}">
                    <materialDesign:PackIcon Kind="Plus"/>
                </Button>
            </StackPanel>
            
            <!-- Right Aligned Tools (Will wrap if needed) -->
             <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
                <!-- Icon Size Slider -->
                <Slider Value="{Binding IconScale}" 
                        Minimum="0.6" Maximum="1.5" 
                        Width="80" Margin="0,0,16,0" 
                        VerticalAlignment="Center"
                        ToolTip="Icon Size"
                        Style="{StaticResource MaterialDesignDiscreteSlider}"/>

                <!-- Refresh Button -->
                <Button Command="{Binding RefreshCommand}" 
                        Style="{StaticResource MaterialDesignIconForegroundButton}" 
                        ToolTip="Refresh Files"
                        Margin="0,0,8,0">
                    <materialDesign:PackIcon Kind="Refresh" Width="24" Height="24"/>
                </Button>

                <!-- Show/Hide Desktop Toggle -->
                <Button Command="{Binding ToggleDesktopCommand}" 
                        Style="{StaticResource MaterialDesignOutlinedButton}" 
                        ToolTip="{Binding OrganizeButtonText}"
                        Margin="0,0,8,0"
                        Padding="8,0"
                        Height="32"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource PrimaryHueMidBrush}">
                    <materialDesign:PackIcon Kind="{Binding OrganizeButtonIcon}"/>
                </Button>

                <!-- Advanced Tools Menu (Rescue) -->
                <materialDesign:PopupBox PlacementMode="BottomAndAlignRightEdges"
                                         ToolTip="Advanced Tools"
                                         Background="{DynamicResource SecondaryHueMidBrush}"
                                         BorderBrush="{DynamicResource SecondaryHueMidBrush}"
                                         Height="32" Width="32">
                    <materialDesign:PopupBox.ToggleContent>
                        <materialDesign:PackIcon Kind="ToolboxOutline" Width="20" Height="20" Foreground="White"/>
                    </materialDesign:PopupBox.ToggleContent>
                    
                    <StackPanel>
                        <Button Command="{Binding RescueCommand}" ToolTip="Group loose files into 'FocusPanel_Recovered'">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Lifebuoy" Margin="0,0,8,0" Foreground="Red"/>
                                <TextBlock Text="Emergency Rescue"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding SmartRescueCommand}" ToolTip="Intelligently group files by time and context">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Brain" Margin="0,0,8,0" Foreground="#673AB7"/>
                                <TextBlock Text="Smart Grouping"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </materialDesign:PopupBox>
            </StackPanel>
        </WrapPanel>

        <!-- Main Content: List of Partitions (Vertical Stack) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Partitions}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{Binding PartitionColumns, FallbackValue=1}" VerticalAlignment="Top"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource PartitionCardStyle}"
                                AllowDrop="True"
                                Drop="Partition_Drop" 
                                DragEnter="Partition_DragEnter" 
                                DragLeave="Partition_DragLeave">
                            <StackPanel>
                                <!-- Partition Header -->
                                <Grid Height="48" Background="Transparent">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Toggle Button (Chevron) -->
                                    <ToggleButton IsChecked="{Binding IsExpanded}" 
                                                  Style="{StaticResource MaterialDesignExpandCollapseToggleStyle}" 
                                                  Width="24" Height="24" 
                                                  Margin="12,0,0,0"/>
                                    
                                    <!-- Title Area -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                                        <Border Background="{DynamicResource PrimaryHueLightBrush}" CornerRadius="8" Margin="8,0,0,0" Padding="6,1">
                                            <TextBlock Text="{Binding Files.Count}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Actions Menu -->
                                    <materialDesign:PopupBox Grid.Column="2" PlacementMode="BottomAndAlignRightEdges" Margin="0,0,8,0">
                                        <StackPanel>
                                            <Button Command="{Binding DataContext.DeletePartitionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding IsCustom, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="TrashCanOutline" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Delete Partition"/>
                                                </StackPanel>
                                            </Button>
                                            <Button>
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="RenameBox" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Rename (Coming Soon)"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </materialDesign:PopupBox>
                                </Grid>
                                
                                <!-- Partition Content -->
                                <ScrollViewer Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" 
                                              MaxHeight="450" 
                                              VerticalScrollBarVisibility="Auto"
                                              Margin="4,0,4,8">
                                    <ItemsControl ItemsSource="{Binding Files}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource FileItemContainerStyle}" ToolTip="{Binding FullPath}">
                                                    <!-- Context Menu -->
                                                    <Border.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="Clear Partition" 
                                                                      Command="{Binding Data.AssignToPartitionCommand, Source={StaticResource VmProxy}}" 
                                                                      CommandParameter=""/>
                                                            <Separator/>
                                                            <MenuItem Header="Move to" ItemsSource="{Binding Data.Partitions, Source={StaticResource VmProxy}}">
                                                                <MenuItem.ItemContainerStyle>
                                                                    <Style TargetType="MenuItem" BasedOn="{StaticResource MaterialDesignMenuItem}">
                                                                        <Setter Property="Header" Value="{Binding Name}"/>
                                                                        <Setter Property="Command" Value="{Binding Data.AssignToPartitionCommand, Source={StaticResource VmProxy}}"/>
                                                                        <Setter Property="CommandParameter" Value="{Binding Name}"/>
                                                                    </Style>
                                                                </MenuItem.ItemContainerStyle>
                                                            </MenuItem>
                                                        </ContextMenu>
                                                    </Border.ContextMenu>

                                                    <Border.InputBindings>
                                                        <MouseBinding Gesture="LeftClick" 
                                                                      Command="{Binding DataContext.SelectFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      CommandParameter="{Binding}"/>
                                                        <MouseBinding Gesture="LeftDoubleClick" 
                                                                      Command="{Binding DataContext.OpenFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      CommandParameter="{Binding}"/>
                                                    </Border.InputBindings>
                                                
                                                    <Grid Margin="4">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        
                                                        <!-- Icon -->
                                                        <Grid Grid.Row="0" Margin="4">
                                                            <Image Source="{Binding Icon}" 
                                                                   Width="{Binding DataContext.IconImageSize, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                   Height="{Binding DataContext.IconImageSize, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                                   RenderOptions.BitmapScalingMode="HighQuality">
                                                            </Image>
                                                        </Grid>

                                                        <!-- Footer Info -->
                                                        <TextBlock Grid.Row="1" 
                                                                   Text="{Binding DisplayName}" 
                                                                   TextTrimming="CharacterEllipsis" 
                                                                   TextWrapping="NoWrap" 
                                                                   HorizontalAlignment="Center" 
                                                                   TextAlignment="Center" 
                                                                   FontWeight="Regular" 
                                                                   FontSize="11"
                                                                   Margin="0,4,0,0"
                                                                   Foreground="{DynamicResource MaterialDesignBody}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>